# Connection string for the harper-ops Supabase Postgres (transaction pooler).
# Server-side only — used by /api/partner to persist partner signups.
HARPER_OPS_DATABASE_URL=postgresql://USER:PASSWORD@HOST:6543/postgres

# --- Partner confirmation email (Resend) ---
# Server-side only. Sends a best-effort confirmation to the person who submits
# the "Become a Partner" form. If RESEND_API_KEY is unset, the lead is still
# saved and the email is simply skipped (it never blocks lead capture).
#
# Get an API key at https://resend.com. To deliver as @harperinsure.com the
# harperinsure.com domain must first be VERIFIED in Resend (DNS records).
RESEND_API_KEY=re_your_api_key_here

# The "from" address on the confirmation. Only delivers as @harperinsure.com
# once that domain is verified in Resend. Before verification, you can test by
# temporarily setting this to: Harper Partners <onboarding@resend.dev>
PARTNER_CONFIRMATION_FROM=Harper Partners <partnerships@harperinsure.com>

# Where replies go. Leave as the real partnerships inbox.
PARTNER_CONFIRMATION_REPLY_TO=partnerships@harperinsure.com
