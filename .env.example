# Connection string for the harper-ops Supabase Postgres (transaction pooler).
# Server-side only — used by /api/partner to persist partner signups.
HARPER_OPS_DATABASE_URL=postgresql://USER:PASSWORD@HOST:6543/postgres

# --- Partner confirmation email (Gmail API) ---
# Server-side only. Sends a best-effort confirmation to the person who submits
# the "Become a Partner" form, delivered through the Gmail API as
# partnerships@harperinsure.com. If these vars are unset, the lead is still
# saved and the email is simply skipped (it never blocks lead capture).
#
# Credentials come from a Google OAuth2 client. Obtain GOOGLE_REFRESH_TOKEN by
# running `node scripts/get-gmail-token.mjs` and signing in as the mailbox in
# USER_GOOGLE_EMAIL. Never commit real values — set them in .env.local locally
# and in the host's environment (e.g. Railway) in production.
GOOGLE_OAUTH_CLIENT_ID=your_client_id.apps.googleusercontent.com
GOOGLE_OAUTH_CLIENT_SECRET=your_client_secret
USER_GOOGLE_EMAIL=partnerships@harperinsure.com
GOOGLE_REFRESH_TOKEN=your_refresh_token

# Where replies go. Leave as the real partnerships inbox.
PARTNER_CONFIRMATION_REPLY_TO=partnerships@harperinsure.com
